{
  "name": "sense-grain",
  "version": "0.1.0",
  "private": true,
  "description": "Sense Grain monorepo for mobile, web, Firebase, and shared design systems.",
  "workspaces": [
    "mobile-app",
    "web-app",
    "shared-design",
    "firebase/functions"
  ],
  "scripts": {
    "mobile": "npm --workspace mobile-app run start",
    "web": "npm --workspace web-app run dev",
    "firebase:emulators": "firebase emulators:start --config firebase/firebase.json",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1"
  }
}
