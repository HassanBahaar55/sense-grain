rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /devices/{deviceId} {
      allow read: if request.auth != null;
      allow write: if false; // only Cloud Functions (Admin SDK) write here
    }

    match /grainReadings/{readingId} {
      allow read: if request.auth != null;
      allow write: if false; // only Cloud Functions write here
    }

    match /storageBins/{storageBinId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Live warehouse sensor state — written every minute by Cloud Function
    match /warehouseReadings/{warehouseId} {
      allow read: if request.auth != null;
      allow write: if false; // only Cloud Functions (Admin SDK) write here
    }

    // Active alerts — created/resolved by Cloud Function
    match /alerts/{alertId} {
      allow read: if request.auth != null;
      allow write: if false; // only Cloud Functions write here
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
