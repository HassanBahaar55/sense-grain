rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isApproved() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approvalStatus == 'approved';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ─── User profiles ────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      // Users can create their own profile but cannot self-assign admin role
      allow create: if isOwner(uid) && !('role' in request.resource.data);
      // Only admin can set approvalStatus, role, or tickIntervalSeconds
      allow update: if isAdmin() ||
        (isOwner(uid) && request.resource.data.diff(resource.data)
          .affectedKeys().hasOnly(['displayName', 'updatedAt']));
      allow delete: if isAdmin();
    }

    // ─── Registration requests ────────────────────────────────────────────────

    match /userRequests/{uid} {
      allow create: if isOwner(uid);
      allow read:   if isOwner(uid) || isAdmin();
      allow update, delete: if isAdmin();
    }

    // ─── Resource requests (warehouse / zone / sensor) ────────────────────────

    match /resourceRequests/{reqId} {
      allow create: if isApproved() && request.resource.data.uid == request.auth.uid;
      allow read:   if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // ─── Per-user account data ────────────────────────────────────────────────

    match /accounts/{uid}/{document=**} {
      allow read, write: if (isOwner(uid) && isApproved()) || isAdmin();
    }

    // ─── Catch-all deny ───────────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
